# Copy to .env and fill in values before running.
# .env is gitignored — never commit it.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinellm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth — Microsoft Entra ID ─────────────────────────────────────────────────
# Leave blank in local dev; auth middleware falls back to a dev bypass when DEBUG=true
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# ── Key management ────────────────────────────────────────────────────────────
# Local dev ONLY — bypasses Azure Key Vault.
# NEVER set this to true in any deployed environment.
DEV_KEY_VAULT_BYPASS=true

# Leave unset when attacking Ollama (no API key needed).
# Set if pointing the local dev target at a real API.
# DEV_TARGET_API_KEY=

# ── Local dev target (Ollama) ─────────────────────────────────────────────────
# Run: ollama pull llama3
# Ollama exposes an OpenAI-compatible endpoint on this address from Docker Compose.
OLLAMA_ENDPOINT=http://host.docker.internal:11434/v1
OLLAMA_DEPLOYMENT=llama3

# ── Azure Key Vault (production only) ─────────────────────────────────────────
# KEY_VAULT_URL=https://your-vault.vault.azure.net/
